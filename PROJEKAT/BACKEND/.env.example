# --- Server Configuration ---
PORT=3000
NODE_ENV=development

# --- Database Configuration ---
# Example for local: postgresql://postgres:<password>@localhost:5433/grupa12app
POSTGRES_PASSWORD=
DATABASE_URL=
USE_DOCKER_DB=true

# --- Security ---
# Secret for express-session
SESSION_SECRET=

# --- Frontend Connection ---
# Comma-separated list. Set the Railway frontend URL in production.
FRONTEND_ORIGIN=http://localhost:4200
# FRONTEND_ORIGINS=http://localhost:4200,https://frontend-production-16f75.up.railway.app

# --- Internal AI Service ---
# Local host access: http://localhost:8000
# Docker internal access from backend container: http://ai-service:8000
AI_SERVICE_URL=http://localhost:8000
# Production: https://ai-service-production-e732.up.railway.app

# --- Gemini AI Assistant ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Keycloak Configuration ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=Grupa12SI
KEYCLOAK_CLIENT_ID=public
KEYCLOAK_CLIENT_SECRET=

# --- JWT Configuration (for validation) ---
# JWT_ISSUER and JWKS_URI are derived from KEYCLOAK_URL when omitted.
JWT_ISSUER=http://localhost:8080/realms/Grupa12SI
JWT_AUDIENCE=account
JWKS_URI=http://localhost:8080/realms/Grupa12SI/protocol/openid-connect/certs
